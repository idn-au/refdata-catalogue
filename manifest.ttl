PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX mrr: <https://prez.dev/ManifestResourceRoles/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX prez: <https://prez.dev/>
PREFIX prof: <http://www.w3.org/ns/dx/prof/>
PREFIX schema: <https://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

[]
    a prez:Manifest ;
    prof:hasResource
        [
            prof:hasArtifact "catalogue.ttl" ;
            prof:hasRole mrr:CatalogueData ;
            schema:description "The definition of, and metadata for, the container which here is a schema:DataCatalog object" ;
            schema:name "Catalogue Definition" ;
        ] ,
        [
            prof:hasArtifact "vocabs/sync/*.ttl" ;
            prof:hasRole mrr:ResourceData ;
            schema:description "skos:ConceptScheme objects in RDF (Turtle) files in the vocabs/sync/ folder for syncing" ;
            schema:name "Syncable Vocabs" ;
#            schema:additionalType skos:ConceptScheme ;
            dcterms:conformsTo <https://linked.data.gov.au/def/vocpub/validator> ;
        ] ,
        [
            prof:hasArtifact "datasets/metadata/*.ttl" ;
            prof:hasRole mrr:ResourceData ;
            schema:description "schema:Dataset objects in RDF (Turtle) files in the datasets/metadata/ folder for syncing" ;
            schema:name "Syncable Datasets" ;
#            schema:additionalType schema:Dataset ;
        ] ,
        [
            prof:hasArtifact "https://raw.githubusercontent.com/RDFLib/prez/refs/heads/main/prez/reference_data/profiles/ogc_records_profile.ttl" ;
            prof:hasRole mrr:CatalogueAndResourceModel ;
            schema:description "The default Prez profile for Records API" ;
            schema:name "Profile Definition" ;
        ] ,
        [
            prof:hasArtifact "labels.ttl" ;
            prof:hasRole mrr:CompleteCatalogueAndResourceLabels ;
            schema:description "An RDF file containing all the labels for the container content" ;
            schema:name "Labels" ;
        ] ,
        [
            prof:hasArtifact "onts/*.ttl" ;
            prof:hasRole mrr:ResourceData ;
            schema:description "Ontologies for syncing" ;
            schema:name "Syncable Ontologies" ;
#            schema:additionalType owl:Ontology ;
            dcterms:conformsTo <https://linked.data.gov.au/def/ontpub/validator> ;
        ] ;
.