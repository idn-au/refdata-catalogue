PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX geo: <http://www.opengis.net/ont/geosparql#>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

<https://data.idnau.org/pid/capad2020>
    a schema:Dataset ;
    dcterms:provenance "This dataset was assembled from CAPAD data downloaded from DCCEEWW via data.gov.au" ;
    geo:hasBoundingBox
        [
            a geo:Geometry ;
            geo:asWKT "POLYGON ((96.0 -45.0, 168.0 -45.0, 168.0 -9.0, 96.0 -9.0, 96.0 -45.0))"^^geo:wktLiteral ;
        ] ;
    rdfs:member
        <https://data.idnau.org/pid/capad2020/ipa> ,
        <https://data.idnau.org/pid/capad2020/npa> ;
    schema:citation "https://data.gov.au/dataset/ds-environment-9984a9fd-3dd0-4e38-bfbd-7e788fa851a1/details?q=capad%202020"^^xsd:anyURI ;
    schema:creator <https://linked.data.gov.au/org/idn> ;
    schema:dateCreated "2023-05-15"^^xsd:date ;
    schema:dateModified "2023-05-15"^^xsd:date ;
    schema:description "The Collaborative Australian Protected Areas Database (CAPAD) 2020 provides both spatial and textual information about government, Indigenous and privately protected areas for Australia, in both the marine and terrestrial environments." ;
    schema:name "Collaborative Australian Protected Areas Database (CAPAD) 2020" ;
    schema:publisher <https://linked.data.gov.au/org/idn> ;
.

<https://data.idnau.org/pid/capad2020/ipa>
    a geo:FeatureCollection ;
    geo:hasBoundingBox
        [
            a geo:Geometry ;
            geo:asWKT "POLYGON ((96.0 -45.0, 168.0 -45.0, 168.0 -9.0, 96.0 -9.0, 96.0 -45.0))"^^geo:wktLiteral ;
        ] ;
    prov:qualifiedAttribution 
        [
            a prov:Attribution ;
            dcat:hadRole <http://def.isotc211.org/iso19115/-1/2018/CitationAndResponsiblePartyInformation/code/CI_RoleCode/custodian> ;
            schema:agent <https://linked.data.gov.au/org/dcceew> ;
        ] ,
        [
            a prov:Attribution ;
            dcat:hadRole <http://def.isotc211.org/iso19115/-1/2018/CitationAndResponsiblePartyInformation/code/CI_RoleCode/originator> ;
            schema:agent <https://linked.data.gov.au/org/dcceew> ;
        ] ,
        [
            a prov:Attribution ;
            dcat:hadRole <http://def.isotc211.org/iso19115/-1/2018/CitationAndResponsiblePartyInformation/code/CI_RoleCode/contributor> ;
            schema:agent <https://linked.data.gov.au/org/idn> ;
        ] ;
    schema:description "Indigenous Protected Area features from the CAPAD2020 Dataset"@en ;
    schema:name "Indigenous Protected Areas"@en ;
.

<https://data.idnau.org/pid/capad2020/npa>
    a geo:FeatureCollection ;
