PREFIX cs: <https://data.idnau.org/pid/vocab/cat-obj-roles>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

schema:Book
    a
        skos:Concept ,
        schema:CreativeWork ;
    rdfs:isDefinedBy <https://schema.org> ;
    skos:definition "A book."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Book"@en ;
.

schema:Dataset
    a
        skos:Concept ,
        schema:CreativeWork ;
    rdfs:isDefinedBy <https://schema.org> ;
    skos:definition "A body of structured information describing some topic(s) of interest."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Dataset"@en ;
.

schema:DefinedTermSet
    a
        skos:Concept ,
        schema:CreativeWork ;
    rdfs:isDefinedBy <https://schema.org> ;
    skos:definition "A set of defined terms, for example a set of categories or a classification scheme, a glossary, dictionary or enumeration."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Defined Term Set"@en ;
.

schema:DigitalDocument
    a
        skos:Concept ,
        schema:CreativeWork ;
    rdfs:isDefinedBy <https://schema.org> ;
    skos:definition "An electronic file or document."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Digital Document"@en ;
.

schema:Map
    a
        skos:Concept ,
        schema:CreativeWork ;
    rdfs:isDefinedBy <https://schema.org> ;
    skos:definition "A map."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Map"@en ;
.

schema:Movie
    a
        skos:Concept ,
        schema:CreativeWork ;
    rdfs:isDefinedBy <https://schema.org> ;
    skos:definition "A movie."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Movie"@en ;
.

schema:Painting
    a
        skos:Concept ,
        schema:CreativeWork ;
    rdfs:isDefinedBy <https://schema.org> ;
    skos:definition "A painting."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Painting"@en ;
.

schema:Photograph
    a
        skos:Concept ,
        schema:CreativeWork ;
    rdfs:isDefinedBy <https://schema.org> ;
    skos:definition "A photograph."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Photograph"@en ;
.

schema:Report
    a
        skos:Concept ,
        schema:CreativeWork ;
    rdfs:isDefinedBy <https://schema.org> ;
    rdfs:subClassOf schema:Article ;
    skos:definition "A Report generated by governmental or non-governmental organization."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Report"@en ;
.

schema:Sculpture
    a
        skos:Concept ,
        schema:CreativeWork ;
    rdfs:isDefinedBy <https://schema.org> ;
    skos:definition "A piece of sculpture."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Sculpture"@en ;
.

schema:SoftwareApplication
    a
        skos:Concept ,
        schema:CreativeWork ;
    rdfs:isDefinedBy <https://schema.org> ;
    skos:definition "A software application."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Software Application"@en ;
.

schema:SoftwareSourceCode
    a
        skos:Concept ,
        schema:CreativeWork ;
    rdfs:isDefinedBy <https://schema.org> ;
    skos:definition "Computer programming source code. Example: Full (compile ready) solutions, code snippet samples, scripts, templates."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Software Source Code"@en ;
.

schema:Thesis
    a
        skos:Concept ,
        schema:CreativeWork ;
    rdfs:isDefinedBy <https://schema.org> ;
    skos:definition "A thesis or dissertation document submitted in support of candidature for an academic degree or professional qualification."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Thesis"@en ;
    schema:isPartOf <https://bib.schema.org> ;
    schema:source "http://www.productontology.org/id/Thesis"^^xsd:anyURI ;
.

schema:VisualArtwork
    a
        skos:Concept ,
        schema:CreativeWork ;
    rdfs:isDefinedBy <https://schema.org> ;
    skos:definition "A work of art that is primarily visual in character."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Visual Artwork"@en ;
.

schema:WebSite
    a
        skos:Concept ,
        schema:CreativeWork ;
    rdfs:isDefinedBy <https://schema.org> ;
    skos:definition "A WebSite is a set of related web pages and other items typically served from a single web domain and accessible via URLs."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Web Site"@en ;
.

<https://linked.data.gov.au/org/idn>
    a schema:Organization ;
    schema:name "Indigenous Data Network" ;
    schema:url "https://www.idnau.org"^^xsd:anyURI ;
.

schema:Article
    a
        skos:Concept ,
        schema:CreativeWork ;
    rdfs:isDefinedBy <https://schema.org> ;
    skos:definition "An article, such as a news article or piece of investigative report. Newspapers and magazines have articles of many different types and this is intended to cover them all.\\n\\nSee also [blog post](http://blog.schema.org/2014/09/schemaorg-support-for-bibliographic_2.html)."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Article"@en ;
    schema:contributor <https://schema.org/docs/collab/rNews> ;
.

cs:
    a skos:ConceptScheme ;
    skos:definition "The types of things in a catalogue"@en ;
    skos:hasTopConcept
        schema:Article ,
        schema:Book ,
        schema:Dataset ,
        schema:DefinedTermSet ,
        schema:DigitalDocument ,
        schema:Map ,
        schema:Movie ,
        schema:Painting ,
        schema:Photograph ,
        schema:Report ,
        schema:Sculpture ,
        schema:SoftwareApplication ,
        schema:SoftwareSourceCode ,
        schema:Thesis ,
        schema:VisualArtwork ,
        schema:WebSite ;
    skos:historyNote "This vocabulary was established in 2026 to assist the IDN with managing multiple catalogues with multiple types of things in them."@en ;
    skos:prefLabel "Catalogued Object Types"@en ;
    skos:scopeNote "" ;
    schema:copyrightNotice "(c) Indigenous Data Network, 2026" ;
    schema:creator <https://linked.data.gov.au/org/idn> ;
    schema:dateCreated "2026-03-10"^^xsd:date ;
    schema:dateModified "2026-03-10"^^xsd:date ;
    schema:license <http://purl.org/NET/rdflicense/cc-by4.0> ;
    schema:publisher <https://linked.data.gov.au/org/idn> ;
    schema:status <https://linked.data.gov.au/def/reg-statuses/stable> ;
.
