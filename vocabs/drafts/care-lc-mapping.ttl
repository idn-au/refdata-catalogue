# provisionally, skos:relatedMatch is assigned only to narrower principles (i.e. "care:C1", NOT "care:C"). Assuming the Care top concepts would inherit the skos:relatedMatch semantics.

PREFIX cs: <http://linked.data.gov.au/def/care>
PREFIX bc: <https://data.idnau.org/pid/vocab/bc-labels/>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX care: <http://linked.data.gov.au/def/care/>
PREFIX lcn: <https://data.idnau.org/pid/vocab/lc-notices/>
