PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX sdo: <https://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX tk: <https://data.idnau.org/pid/vocab/tk-labels/>
PREFIX void:  <http://rdfs.org/ns/void#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

<https://data.idnau.org/def/care-lc-mapping>
    a owl:Ontology, void:Linkset ;
    sdo:dateCreated "2026-03-04"^^xsd:date ;
    dcterms:creator <https://linked.data.gov.au/org/idn> ;
    skos:prefLabel "CARE --> Local Contexts label mappings"@en ;
    skos:definition "Standalone mapping assertions linking CARE principles to Local Contexts TK and BC labels"@en ;
    skos:historyNote "Created for scoring and inference use"@en ;
    owl:versionInfo "0.1.0" ;
    owl:versionIRI <https://data.idnau.org/def/care-lc-mapping/0.1.0> ;
    void:subjectsTarget <http://linked.data.gov.au/def/care> ;
    void:objectsTarget  <https://data.idnau.org/pid/vocab/tk-labels> ;
    void:linkPredicate  skos:relatedMatch ;
    dcterms:identifier "carelcmap"^^xsd:token ;
