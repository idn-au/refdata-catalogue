PREFIX bccs: <https://data.idnau.org/pid/vocab/bc-labels>
PREFIX idn: <https://linked.data.gov.au/org/idn>
PREFIX kai: <https://kurrawong.ai>
PREFIX lcncs: <https://data.idnau.org/pid/vocab/lc-notices>
PREFIX lcont: <https://data.idnau.org/pid/lc-ont#>
PREFIX odrl: <http://www.w3.org/ns/odrl/2/>
PREFIX ont: <https://data.idnau.org/pid/lc-ont>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX sdo: <https://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX tkcs: <https://data.idnau.org/pid/vocab/tk-labels>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

lcont:followProtocol a odrl:Action ;
    rdfs:isDefinedBy lcont: ;
    skos:prefLabel "Follow protocol"@en ;
    sdo:description "Action indicating that a protocol must be followed" ;
    sdo:name "Follow Protocol" .

lcont:relatedNotice a owl:Property ;
    rdfs:domain lcont:BCLabel,
        lcont:TKLabel ;
    rdfs:isDefinedBy lcont: ;
    rdfs:range lcont:LCNotice ;
    sdo:description "Property indicating that a Local Contexts Label is related in some way ot a Local Contexts Notice" ;
    sdo:name "Related Notice" .

lcont:templateText a owl:DatatypeProperty ;
    rdfs:domain lcont:BCLabel,
        lcont:LCNotice,
        lcont:TKLabel ;
    rdfs:isDefinedBy lcont: ;
    rdfs:range rdf:langString ;
    sdo:description "A prescriptive text string associated with a Label or Notice that provides boilerplate wording intended to be reused or customised by end-users. Distinct from skos:example, which is illustrative only." ;
    sdo:name "Template Text" .

lcont:BCLabel a owl:Class ;
    rdfs:isDefinedBy ont: ;
    sdo:description "A SKOS Concept representing a Biocultural Label from the Local Contexts framework." ;
    sdo:name "Biocultural Label" .

lcont:LCNotice a owl:Class ;
    rdfs:isDefinedBy ont: ;
    sdo:description "The class of all Notice concepts from the Local Contexts framework."@en ;
    sdo:name "Local Contexts Notice"@en .

lcont:TKLabel a owl:Class ;
    rdfs:isDefinedBy ont: ;
    sdo:description "A SKOS Concept representing a Traditional Knowledge Label from the Local Contexts framework." ;
    sdo:name "Traditional Knowledge Label" .

ont: a owl:Ontology ;
    rdfs:seeAlso bccs:,
        lcncs:,
        tkcs: ;
    owl:versionIRI lcont:0.2 ;
    skos:historyNote """2026-02 NJC: made OntPub-conformant

2025-09 LK: created""" ;
    sdo:codeRepository "https://github.com/idn-au/refdata-catalogue"^^xsd:anyURI ;
    sdo:copyrightHolder kai: ;
    sdo:copyrightNotice "KurrawongAI, 2026" ;
    sdo:copyrightYear "2026"^^xsd:gYear ;
    sdo:creator kai: ;
    sdo:dateCreated "2025-09-23"^^xsd:date ;
    sdo:dateIssued "2026-03-31"^^xsd:date ;
    sdo:dateModified "2026-02-24"^^xsd:date ;
    sdo:description "Defines TKLabel and BCLabel classes as subclasses of skos:Concept, and lc:templateText for associating reusable boilerplate text with Local Contexts labels." ;
    sdo:license <http://purl.org/NET/rdflicense/cc-by4.0> ;
    sdo:name "Local Contexts Label Extension Vocabulary" ;
    sdo:publisher idn: ;
    sdo:version "0.2" .

